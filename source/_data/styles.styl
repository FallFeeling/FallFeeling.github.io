// Subtle NexT polish for Bilala's Blog.
:root {
  --body-bg-color: #f5f7fb;
  --content-bg-color: rgba(255, 255, 255, 0.92);
  --link-color: #0f766e;
  --link-hover-color: #2563eb;
  --btn-default-bg: #0f766e;
  --btn-default-color: #fff;
  --card-bg-color: rgba(255, 255, 255, 0.94);
}

.main-inner {
  max-width: 1180px;
}

.header-inner,
.sidebar-inner,
.post-block,
.pagination,
.comments {
  border-radius: 8px;
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
}

.site-brand-container {
  background: linear-gradient(135deg, #0f766e, #2563eb);
}

.site-title {
  letter-spacing: 0;
}

.site-subtitle {
  opacity: 0.86;
}

.post-title-link::before {
  background: #14b8a6;
}

.post-button .btn {
  border-radius: 6px;
}

.menu .menu-item a:hover,
.sidebar-nav .sidebar-nav-active {
  color: #0f766e;
}
